# ── Required secrets (copy to .env and fill in) ───────────────────────────
# JWT signing secret (Base64-encoded, 256-bit minimum)
JWT_SECRET=

# ── Optional overrides (defaults work for local dev) ──────────────────────
# Frontend URL used for CORS allowed-origins and password-reset links
FRONTEND_URL=http://localhost:4200

# Mail (SendGrid or SMTP)
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USER=apikey
MAIL_PASS=
MAIL_FROM=noreply@booker.app
